# NETRA environment configuration
# Copy to .env (locally) or set in Catalyst AppSail → Environment Variables.
# Every variable is OPTIONAL: NETRA runs fully with none set (local providers).
# Each one you set flips that capability from local → Catalyst. See catalyst/DEPLOY.md.

# ── Core ────────────────────────────────────────────────────────────────────
# 'local' (default) = synthetic seed via filesystem · 'catalyst' = Catalyst Data Store
NETRA_ENV=local
# Override seed directory if the app runs from a different CWD (rarely needed)
# NETRA_SEED_DIR=./data/seed

# ── Catalyst QuickML LLM Serving (grounded RAG narration) ──────────────────
# Console → QuickML → Generative AI → LLM Serving → Models → API Details
# NETRA_LLM_URL=https://<your-endpoint>
# NETRA_LLM_KEY=<zoho-oauth2-token with scope QuickML.deployment.READ>
# NETRA_LLM_AUTH_SCHEME=Zoho-oauthtoken
# NETRA_LLM_MODEL=Qwen2.5-14B-Instruct

# ── Voice ───────────────────────────────────────────────────────────────────
# English ASR/TTS via Catalyst Zia (browser Web Speech is the local fallback)
# NETRA_ASR=zia
# NETRA_TTS=zia
# Kannada voice via Bhashini/AI4Bharat (Catalyst Zia has no Kannada ASR/TTS yet —
# documented allowed third-party; see catalyst/DEPLOY.md §4)
# NETRA_ASR_KN=bhashini
# BHASHINI_API_KEY=<key from https://bhashini.gov.in / ULCA>

# ── PDF dossier + storage ───────────────────────────────────────────────────
# NETRA_PDF=smartbrowz          # server-side dossier rendering via Catalyst SmartBrowz
# NETRA_BLOB=stratus            # persist dossiers to Catalyst Stratus
# NETRA_STRATUS_BUCKET=netra-dossiers

# ── Beat Briefing dispatch (catalyst/functions/beatBriefing) ────────────────
# NETRA_MAIL_FROM=<verified sender in Catalyst Mail>
# NETRA_MAIL_TO=<recipient for the nightly briefing>

# ── Auth ────────────────────────────────────────────────────────────────────
# NETRA_AUTH=catalyst           # gate the app behind Catalyst Authentication (hosted login)
